# ─────────────────────────────────────────────────────────────────────────────
# Codara Sandbox Server — Variables de entorno
# Copia este archivo como .env.server y completa los valores reales.
# NUNCA subas .env.server al repositorio (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Puerto del servidor sandbox (por defecto: 3001) ──────────────────────────
# SANDBOX_PORT=3001

# ── GitHub OAuth App ─────────────────────────────────────────────────────────
# Crea tu OAuth App en: https://github.com/settings/applications/new
#
# Homepage URL:        http://localhost:5173
# Callback URL:        http://localhost:3001/auth/github/callback
#
CLIENT_ID=your_github_client_id_here
CLIENT_SECRET=your_github_client_secret_here

# ── URLs (producción) ────────────────────────────────────────────────────────
# FRONTEND_URL=https://edison-enriquez.github.io/Codara
# SERVER_URL=https://your-server-domain.com

# ── JWT ───────────────────────────────────────────────────────────────────────
# Cadena aleatoria larga para firmar los tokens. Genera una con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_random_secret

# ── URLs (solo cambiar en producción) ─────────────────────────────────────────
# FRONTEND_URL=http://localhost:5173
# SERVER_URL=http://localhost:3001
