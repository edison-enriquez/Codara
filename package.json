{
  "name": "codara",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:content": "node scripts/build-content.mjs",
    "dev:slides": "slidev slides/curso-slidev-prueba/slides.md --open",
    "build:slides": "slidev build slides/curso-slidev-prueba/slides.md --out ../../public/slides/curso-slidev-prueba --base /Codara/slides/curso-slidev-prueba/",
    "predev": "npm run build:content && npm run build:slides",
    "dev": "vite",
    "dev:server": "node --env-file=server/.env.server server/sandbox.mjs",
    "dev:all": "concurrently -n FE,BE -c blue,green \"vite\" \"node --env-file=server/.env.server server/sandbox.mjs\"",
    "prebuild": "npm run build:content && npm run build:slides",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval:tutor": "vitest run golden.test live-judge.test",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.84",
    "@monaco-editor/react": "^4.6.0",
    "@types/three": "^0.185.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.22.3",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@slidev/cli": "^52.18.0",
    "@slidev/theme-default": "^0.25.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.3",
    "vite": "^5.4.1",
    "vitest": "^4.1.10"
  }
}
